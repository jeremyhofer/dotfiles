# vim: ft=zsh
# ~/.zprofile — login shells only (after .zshenv, before .zshrc). Login ACTIONS only;
# PATH and env vars live in ~/.zshenv so every context (incl. non-interactive/ssh/GUI) gets them.

[ -f "$HOME/.dotlocal/zprofile" ] && source "$HOME/.dotlocal/zprofile"
{{- if eq .chezmoi.os "linux" }}
{{ includeTemplate "zprofile.linux" . -}}
{{- end }}
