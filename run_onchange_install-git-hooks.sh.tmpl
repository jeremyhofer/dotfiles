#!/bin/sh
# Installs the FALLBACK pre-push leak-guard floor into the chezmoi SOURCE repo
# (.git/hooks/pre-push). The FULL publish-boundary guard (markers + sensitive terms) is
# provided globally by the overlay when present; this floor is what a public-base-only
# clone (no overlay) still gets. The hook lives in .git/hooks (never pushed), so it may
# hold the literal overlay URL; THIS installer is committed+public, so it injects that URL
# via the {{ "{{ .overlayRepo }}" }} template var rather than a literal.
set -eu

src="{{ .chezmoi.sourceDir }}"
[ -d "$src/.git" ] || exit 0          # only meaningful in the git-backed source repo
hook="$src/.git/hooks/pre-push"
mkdir -p "$src/.git/hooks"

cat > "$hook" <<'HOOK'
#!/bin/sh
# Generic pre-push floor for a public-base-only clone (no overlay). The FULL
# publish-boundary guard (markers + sensitive terms) is provided by the overlay's
# global core.hooksPath hook when present; this is only the fallback for a bare clone.
KEY_RE='-----BEGIN[ A-Z]*PRIVATE KEY-----'
OVERLAY='{{ .overlayRepo }}'
zero=0000000000000000000000000000000000000000
block=0
while read -r lref lsha rref rsha; do
  [ "$lsha" = "$zero" ] && continue
  hits=$(git grep -nIE "$KEY_RE" "$lsha" 2>/dev/null || true)
  [ -n "$OVERLAY" ] && hits="$hits
$(git grep -nIF "$OVERLAY" "$lsha" 2>/dev/null || true)"
  hits=$(printf '%s\n' "$hits" | sed '/^$/d')
  [ -n "$hits" ] && { echo "content leak:" >&2; printf '%s\n' "$hits" >&2; block=1; }
done
[ "$block" -ne 0 ] && { echo "pre-push BLOCKED: private key or overlay URL in the push." >&2; exit 1; }
exit 0
HOOK

chmod +x "$hook"
echo "installed pre-push leak guard -> $hook"
