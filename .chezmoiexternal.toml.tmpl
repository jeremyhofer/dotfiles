[".oh-my-zsh"]
    type = "git-repo"
    url = "https://github.com/ohmyzsh/ohmyzsh.git"
    refreshPeriod = "168h"
    [".oh-my-zsh".pull]
        args = ["--ff-only"]

[".oh-my-zsh/custom/plugins/nx-completion"]
    type = "git-repo"
    url = "https://github.com/jscutlery/nx-completion.git"
    refreshPeriod = "168h"
    [".oh-my-zsh/custom/plugins/nx-completion".pull]
        args = ["--ff-only"]

[".tmux/plugins/tpm"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tpm.git"
    refreshPeriod = "168h"
    [".tmux/plugins/tpm".pull]
        args = ["--ff-only"]
